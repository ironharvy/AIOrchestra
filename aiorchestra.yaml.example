# AIOrchestra configuration
# Copy this to aiorchestra.yaml and adjust for your project.

label: "claude"

ai:
  provider: "claude-code"   # "claude-code", "codex", "gemini", "opencode", "jules", "ollama"
  model: "claude-opus-4-6"  # model hint forwarded to the provider's --model flag
  max_retries: 3

# OpenCode provider example:
# ai:
#   provider: "opencode"
#   model: "gpt-4o"         # optional — passed as --model
#   yes: true               # auto-approve tool use (default: true)

test:
  command: "pytest"
  lint_command: "ruff check ."

review:
  enabled: true
  provider: "claude-code"
  # Static analysis (T1) is disabled by default.  Flip enabled to true to
  # run Semgrep & Bandit during the validate step (before a PR is created).
  # The commands below override the built-in defaults; omit to use them.
  tiers:
    - name: "static-analysis"
      enabled: true
      # commands:                  # optional — defaults to semgrep + bandit
      #   - "bandit -c pyproject.toml -r ."
      #   - "semgrep scan --config auto --error ."

ci:
  enabled: true
  timeout: 600
  poll_interval: 30
  no_checks_grace: 120  # seconds to wait before treating "no CI checks" as a pass

# Sentry error tracking (optional — requires `pip install aiorchestra[sentry]`).
# The DSN can also be set via the SENTRY_DSN environment variable.
sentry:
  dsn: ""                        # paste your Sentry DSN here
  environment: "production"      # or "staging", "development", etc.
  traces_sample_rate: 0.0        # 0.0–1.0; keep low on free tier

# OSINT enrichment — gather external intelligence before implementation.
# Runs shell tools locally and summarises via a local Ollama model.
# Zero cloud AI tokens spent.
osint:
  enabled: false             # flip to true to activate
  collectors:                # which tools to run (must be on PATH)
    - whois
    - dig
    - dig-mx
    - dig-ns
    - dig-txt
    - host
    - http-headers
    # - nmap-quick           # uncomment if nmap is installed
  targets: []                # explicit targets; auto-extracted from issue text when empty
  ollama:
    enabled: true            # summarise raw output via local LLM
    endpoint: "http://localhost:11434"
    model: "mistral"         # any model that fits your GPU (e.g. llama3, phi3)
    timeout: 120
