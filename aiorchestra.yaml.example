# AIOrchestra configuration
# Copy this to aiorchestra.yaml and adjust for your project.

label: "claude"

ai:
  provider: "claude-code"   # uses the `claude` CLI
  model: "sonnet"           # model hint for --model flag
  max_retries: 3

test:
  command: "pytest"
  lint_command: "ruff check ."

review:
  enabled: true
  provider: "claude-code"
  tiers:
    - name: "static-analysis"
      enabled: true
      commands:
        - "bandit -c pyproject.toml -r ."
        - "semgrep scan --config auto --error ."

ci:
  enabled: true
  timeout: 600
  poll_interval: 30

# OSINT enrichment — gather external intelligence before implementation.
# Runs shell tools locally and summarises via a local Ollama model.
# Zero cloud AI tokens spent.
osint:
  enabled: false             # flip to true to activate
  collectors:                # which tools to run (must be on PATH)
    - whois
    - dig
    - dig-mx
    - dig-ns
    - dig-txt
    - host
    - http-headers
    # - nmap-quick           # uncomment if nmap is installed
  targets: []                # explicit targets; auto-extracted from issue text when empty
  ollama:
    enabled: true            # summarise raw output via local LLM
    endpoint: "http://localhost:11434"
    model: "mistral"         # any model that fits your GPU (e.g. llama3, phi3)
    timeout: 120
